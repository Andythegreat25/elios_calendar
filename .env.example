# Firebase Configuration
# Copia questo file in .env e sostituisci i valori con quelli del tuo progetto Firebase.
# Trovi questi valori in: Firebase Console → Project Settings → Your Apps → Web App → Config

VITE_FIREBASE_API_KEY="your-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
VITE_FIREBASE_APP_ID="your-app-id"
VITE_FIREBASE_DATABASE_ID="(default)"
# Per database Firestore custom (non quello di default):
# VITE_FIREBASE_DATABASE_ID="your-custom-database-id"
